@model BLL.DTOs.CategoryUpdateDTO

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="max-w-xl mx-auto bg-white p-6 shadow rounded mt-10">

    <h1 class="text-2xl font-bold mb-4">Edit Category</h1>

    <form method="post" action="/Category/Update" class="space-y-4">

        <input type="hidden" name="Id" value="@Model.Id" />

        <input name="Name"
               value="@Model.Name"
               class="w-full border p-2 rounded" />

        <textarea name="Description"
                  class="w-full border p-2 rounded">@Model.Description</textarea>

        <button type="submit"
                class="bg-black text-white px-4 py-2 rounded">
            Update
        </button>

    </form>

</div>