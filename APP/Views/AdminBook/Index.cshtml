@model List<BLL.DTOs.BookDTO>

<div class="p-6">

    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold">Books</h1>

        <a href="/AdminBook/Create"
               class="bg-black text-white px-4 py-2 rounded hover:bg-gray-800">
            + Add Book
        </a>
    </div>

    <div class="overflow-x-auto bg-white shadow rounded-lg">
        <table class="w-full text-left">

            <thead class="bg-gray-100">
                <tr>
                    <th class="p-3">Title</th>
                    <th class="p-3">Author</th>
                    <th class="p-3">Category</th>
                    <th class="p-3">Price</th>
                    <th class="p-3">Stock</th>
                    <th class="p-3 text-center">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var book in Model)
                {
                    <tr class="border-t hover:bg-gray-50">

                        <td class="p-3">@book.Title</td>
                        <td class="p-3">@book.Author</td>
                        <td class="p-3">@book.CategoryName</td>
                        <td class="p-3">৳ @book.Price</td>
                        <td class="p-3">@book.Stock</td>

                        <td class="p-3 text-center space-x-2">

                            <a href="/AdminBook/Edit/@book.Id"
                                   class="text-blue-600 hover:underline">
                                Edit
                            </a>

                            <form method="post"
                                  action="/AdminBook/Delete"
                                  class="inline">
                                <input type="hidden" name="id" value="@book.Id" />
                                <button class="text-red-600 hover:underline">
                                    Delete
                                </button>
                            </form>

                        </td>

                    </tr>
                }
            </tbody>

        </table>
    </div>

</div>