@model BLL.DTOs.BookCreateDTO

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="max-w-3xl mx-auto mt-10 bg-white p-8 shadow rounded">

    <h2 class="text-2xl font-bold mb-6">Add New Book</h2>

    <form method="post" class="space-y-4">

        <input name="Title" placeholder="Title" class="border p-2 w-full" />
        <input name="Author" placeholder="Author" class="border p-2 w-full" />

        <input name="Isbn" placeholder="ISBN" class="border p-2 w-full" />

        <textarea name="Description" placeholder="Description" class="border p-2 w-full"></textarea>

        <input name="Price" type="number" step="0.01" placeholder="Price" class="border p-2 w-full" />

        <input name="Stock" type="number" placeholder="Stock" class="border p-2 w-full" />

        <input name="CoverImageUrl" placeholder="Cover Image URL" class="border p-2 w-full" />

        <input name="Publisher" placeholder="Publisher" class="border p-2 w-full" />

        <input name="PublishedYear" type="number" placeholder="Published Year" class="border p-2 w-full" />

        <input name="Language" placeholder="Language" class="border p-2 w-full" />

        <select name="CategoryId" class="border p-2 w-full">
            @foreach (var cat in ViewBag.Categories)
            {
                <option value="@cat.Id">@cat.Name</option>
            }
        </select>

        <button type="submit" class="bg-black text-white px-4 py-2 rounded">
            Save Book
        </button>

    </form>

</div>