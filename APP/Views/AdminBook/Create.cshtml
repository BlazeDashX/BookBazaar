@model BLL.DTOs.BookCreateDTO

<div class="max-w-3xl mx-auto bg-white p-6 shadow rounded mt-6">

    <h1 class="text-2xl font-bold mb-6">Add New Book</h1>

    <form method="post" class="space-y-4">

        <input name="Title" placeholder="Title"
               class="w-full border p-2 rounded" />

        <input name="Author" placeholder="Author"
               class="w-full border p-2 rounded" />

        <input name="Isbn" placeholder="ISBN"
               class="w-full border p-2 rounded" />

        <textarea name="Description" placeholder="Description"
                  class="w-full border p-2 rounded"></textarea>

        <div class="grid grid-cols-2 gap-4">

            <input name="Price" type="number" placeholder="Price"
                   class="border p-2 rounded" />

            <input name="Stock" type="number" placeholder="Stock"
                   class="border p-2 rounded" />

        </div>

        <input name="CoverImageUrl" placeholder="Image URL"
               class="w-full border p-2 rounded" />

        <input name="Publisher" placeholder="Publisher"
               class="w-full border p-2 rounded" />

        <input name="PublishedYear" placeholder="Published Year"
               class="w-full border p-2 rounded" />

        <input name="Language" placeholder="Language"
               class="w-full border p-2 rounded" />

        <select name="CategoryId"
                class="w-full border p-2 rounded">

            @foreach (var c in ViewBag.Categories)
            {
                <option value="@c.Id">@c.Name</option>
            }

        </select>

        <button class="w-full bg-black text-white p-2 rounded hover:bg-gray-800">
            Save Book
        </button>

    </form>

</div>