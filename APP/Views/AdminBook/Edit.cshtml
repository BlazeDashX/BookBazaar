@model BLL.DTOs.BookUpdateDTO

<div class="max-w-3xl mx-auto bg-white p-6 shadow rounded mt-6">

    <h1 class="text-2xl font-bold mb-6">Edit Book</h1>

    <form method="post" action="/AdminBook/Update" class="space-y-4">

        <input type="hidden" name="Id" value="@Model.Id" />

        <input name="Title"
               value="@Model.Title"
               placeholder="Book Title"
               class="w-full border p-2 rounded" />

        <input name="Author"
               value="@Model.Author"
               placeholder="Author Name"
               class="w-full border p-2 rounded" />

        <input name="Isbn"
               value="@Model.Isbn"
               placeholder="ISBN Number"
               class="w-full border p-2 rounded" />

        <textarea name="Description"
                  placeholder="Book Description"
                  class="w-full border p-2 rounded">@Model.Description</textarea>

        <div class="grid grid-cols-2 gap-4">

            <input name="Price"
                   value="@Model.Price"
                   placeholder="Price"
                   class="border p-2 rounded" />

            <input name="Stock"
                   value="@Model.Stock"
                   placeholder="Stock Quantity"
                   class="border p-2 rounded" />

        </div>

        <input name="CoverImageUrl"
               value="@Model.CoverImageUrl"
               placeholder="Cover Image URL"
               class="w-full border p-2 rounded" />

        <input name="Publisher"
               value="@Model.Publisher"
               placeholder="Publisher"
               class="w-full border p-2 rounded" />

        <input name="PublishedYear"
               value="@Model.PublishedYear"
               placeholder="Published Year"
               class="w-full border p-2 rounded" />

        <input name="Language"
               value="@Model.Language"
               placeholder="Language"
               class="w-full border p-2 rounded" />

        <button class="w-full bg-black text-white p-2 rounded hover:bg-gray-800">
            Update Book
        </button>

    </form>

</div>