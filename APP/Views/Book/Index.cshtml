@model List<BLL.DTOs.BookDTO>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="text-3xl font-bold mb-8">
    All Books
</h1>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">

    @foreach (var book in Model)
    {
        <div class="bg-white rounded-lg shadow p-4">

            <img src="@(book.CoverImageUrl ?? "https://via.placeholder.com/300x400")"
                 class="w-full h-72 object-cover rounded" />

            <div class="mt-4">

                <h2 class="text-xl font-bold">
                    @book.Title
                </h2>

                <p class="text-gray-600">
                    @book.Author
                </p>

                <p class="text-sm text-gray-500 mt-1">
                    @book.CategoryName
                </p>

                <p class="text-lg font-semibold mt-3">
                    ৳ @book.Price
                </p>

                <a href="/Book/Details/@book.Id"
                       class="inline-block mt-4 bg-black text-white px-4 py-2 rounded hover:bg-gray-800">
                    View Details
                </a>

            </div>

        </div>
    }

</div>