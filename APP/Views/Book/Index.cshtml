@model List<BLL.DTOs.BookDTO>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="text-3xl font-bold mb-8">All Books</h1>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

    @foreach (var book in Model)
    {
        <div class="bg-white rounded-xl shadow hover:shadow-lg transition p-4">

            <div class="h-72 w-full overflow-hidden rounded-lg bg-gray-100 flex justify-center">
                <img src="@(book.CoverImageUrl ?? "https://via.placeholder.com/300x400")"
                     class=" h-full " />
            </div>

            <div class="mt-4">

                <h2 class="text-lg font-bold truncate">
                    @book.Title
                </h2>

                <p class="text-gray-600 text-sm">
                    @book.Author
                </p>

                <p class="text-xs text-gray-500 mt-1">
                    @(book.CategoryName ?? "Uncategorized")
                </p>

                <p class="text-lg font-semibold mt-3">
                    ৳ @book.Price
                </p>

                <a href="/Book/Details/@book.Id"
                       class="inline-block mt-4 w-full text-center bg-black text-white px-4 py-2 rounded hover:bg-gray-800">
                    View Details
                </a>

            </div>

        </div>
    }

</div>