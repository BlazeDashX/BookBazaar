@model BLL.DTOs.BookDTO

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="bg-white shadow-lg rounded-xl p-8">

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">

        <!-- IMAGE -->
        <div class="h-[500px] w-full bg-gray-100 rounded-lg overflow-hidden flex justify-center">
            <img src="@(Model.CoverImageUrl ?? "https://via.placeholder.com/400x600")"
                 class="h-full " />
        </div>

        <!-- INFO -->
        <div>

            <h1 class="text-4xl font-bold mb-4">
                @Model.Title
            </h1>

            <p class="text-xl text-gray-600 mb-4">
                By @Model.Author
            </p>

            <div class="space-y-2 text-gray-700">

                <p><span class="font-semibold">Category:</span> @(Model.CategoryName ?? "N/A")</p>

                <p><span class="font-semibold">Publisher:</span> @(Model.Publisher ?? "N/A")</p>

                <p><span class="font-semibold">Year:</span> @(Model.PublishedYear?.ToString() ?? "N/A")</p>

                <p><span class="font-semibold">Language:</span> @(Model.Language ?? "N/A")</p>

            </div>

            <p class="text-3xl font-bold mt-6 mb-4">
                ৳ @Model.Price
            </p>

            <p class="text-gray-700 leading-7">
                @(Model.Description ?? "No description available.")
            </p>

            <div class="mt-6 text-sm">
                <span class="font-semibold">Stock:</span> @Model.Stock
            </div>

        </div>

    </div>

</div>